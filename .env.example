# Database
MONGODB_URI="mongodb+srv://..."
MONGODB_DB_NAME="financeApp" # Use "financeApp_staging" para staging/preview e "financeApp" para producao

# Authentication
JWT_SECRET="sua_chave_secreta_aqui"
NEXTAUTH_URL="https://seu-dominio.com" # Usado para links em emails

# APIs Externas
GEMINI_API_KEY="seu_token_gemini"

# AI Inference Providers (Pipeline de Voz Ultra-Rápido)
GROQ_API_KEY=""                         # Primário: Whisper + LLM (free: 1K req/dia)
CEREBRAS_API_KEY="csk-xxxxxxxxxxxx"                      # Fallback LLM-only (free: 1M tokens/dia)
CLOUDFLARE_ACCOUNT_ID="seu_account_id"                   # Fallback Whisper + LLM (free: 10K neurons/dia)
CLOUDFLARE_API_TOKEN="seu_api_token"
# Modelos (opcionais — defaults configurados no código)
# AI_WHISPER_MODEL="whisper-large-v3-turbo"
# AI_LLM_MODEL="qwen-qwq-32b"
# CEREBRAS_LLM_MODEL="llama-3.3-70b"
# CLOUDFLARE_WHISPER_MODEL="@cf/openai/whisper"
# CLOUDFLARE_LLM_MODEL="@cf/meta/llama-3.1-8b-instruct"

API_TOKEN_N8N="seu_token_n8n"

# Pluggy (Open Finance)
PLUGGY_CLIENT_ID="seu_client_id"
PLUGGY_CLIENT_SECRET="seu_client_secret"
PLUGGY_WEBHOOK_URL="https://seu-dominio.com/api/pluggy/webhook"

# Asaas (Pagamentos)
ASAAS_API_URL="https://sandbox.asaas.com/api/v3" # Produção: https://www.asaas.com/api/v3
ASAAS_API_KEY="sua_api_key_asaas"
ASAAS_WEBHOOK_TOKEN="seu_token_de_webhook_asaas"
NEXT_PUBLIC_APP_URL="https://seu-dominio.com"

# Email
EMAIL_USER="nao-responda@financepro.com"

# Cron Jobs (Segurança)
CRON_SECRET="chave_secreta_cron"

# PWA Web Push VAPID Keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="seu_vapid_public_key_aqui"
VAPID_PRIVATE_KEY="seu_vapid_private_key_aqui"
VAPID_EMAIL="mailto:seu-email@dominio.com"
